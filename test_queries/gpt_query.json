{
    "name": "GPT Query",
    "description": "This is the query which embeds a question, looks it up against a knowledge base, and then combines the result to send to GPT, returning the answer.",
    "sql_form": "SELECT is_yes(llm_response), llm_response FROM (SELECT llm(finalize_question(question, passages)) as llm_response FROM question_source JOIN knowledge_base ON embed(question) TOPK embed(passage) as passages)",
    "operators": [
