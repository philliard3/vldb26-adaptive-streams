            "kind": "udf_source",
            "name": "question_source",
            "id": 0
        },
        {
            "kind": "derive",
            "id": 1,
            "source": 0, 
            "new_field_name": "__no_op__formerly__question_embedding",
            "expression": {
                "kind": "literal",
                "type": "null",
                "value": null
            }
        },
        {
            "kind": "udf_source",
            "name": "knowledge_base",
            "id": 2
        },
        {
            "kind": "derive",
            "id": 3,
            "source": 2,
            "new_field_name": "__no_op__formerly__knowledge_base_embedding",
            "expression": {
                "kind": "literal",
                "type": "null",
                "value": null
            }
        },
        {
            "kind": "chroma_join",
            "id": 4,
            "lookup_stream": 1,
            "index_stream": 3,
            "metric": "euclidean",
            "url": "http://localhost:8000",
            "collection": "sentence-transformers-all-mpnet-base-v2",
            "distance_threshold": 1.5,
            "join_info": {
