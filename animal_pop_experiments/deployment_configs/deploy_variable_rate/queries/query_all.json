{
  "name": "Animal Species Count Query (Dynamic)",
  "description": "Dynamic query for 5 models: ['yolo_nano', 'yolo_small', 'yolo_medium', 'yolo_large', 'yolo_xlarge']",
  "sql_form": "SELECT class_id, COUNT(*) ...",
  "operators": [
    {
      "kind": "udf_source",
      "name": "image_source",
      "id": 0
    },
    {
      "kind": "udf",
      "name": "extract_image_info",
      "id": 1,
      "source": 0
    },
    {
      "description": "use routing_fn to decide which animal model to use",
      "kind": "channel_router",
      "id": 2,
      "source": 1,
      "route_expression": {
        "kind": "udf",
        "name": "routing_fn",
        "args": [
          {
            "kind": "field",
            "name": "height_float"
          },
          {
            "kind": "field",
            "name": "width_float"
          }
        ]
      },
      "routes": [
        3,
        7,
        11,
        15,
        19
      ],
      "backup_route": {
        "kind": "drop"
      },
      "backup_route__unused__null_val": {
        "unused_reason": "if we are only using counts then dropping is the same as forwarding nulls",
        "kind": "forward_with_values",
        "merge_spout_position": 23,
        "values_to_set": [
          {
            "key": "predictions",
            "value": null
          }
        ]
      }
    },
    {
      "description": "route 0, use animal_model_v1 (yolo_nano)",
      "kind": "channel_spout",
      "id": 3,
      "source": 2,
      "timeout": 10,
      "max_age_ns": 1000000000
    },
    {
      "description": "detect and classify animals with yolo_nano",
      "kind": "onnx_inference",
      "id": 4,
      "source": 3,
      "model_path": "./yolo_nano.onnx",
      "args": [
        {
          "kind": "SplitParts",
          "shape_field": "input_shape",
          "buffer_field": "image_buffer"
        }
      ],
      "output_descriptions": [
        "node 1810 dims [1, 100, 92]",
        "node 1811 dims [1, 100, 4]",
        "onnx slice tensor: float32[1,1445,192]"
      ],
      "outputs": [
        {
          "kind": "SplitParts",
          "shape_field": "outputs_shape",
          "buffer_field": "outputs"
        }
      ],
      "unused_outputs": [
        {
          "kind": "SplitParts",
          "shape_field": "prediction_logits_shape",
          "buffer_field": "prediction_logits"
        },
        {
          "kind": "SplitParts",
          "shape_field": "prediction_boxes_shape",
          "buffer_field": "prediction_boxes"
        },
        {
          "kind": "SplitParts",
          "shape_field": "unknown_slice_shape",
          "buffer_field": "unknown_slice"
        }
      ]
    },
    {
      "kind": "udf",
      "id": 5,
      "source": 4,
      "name": "split_tuple_yolos",
      "description": "apply softmax/normalization and split detections"
    },
    {
      "kind": "merge",
      "id": 6,
      "source": 5,
      "parent": 23,
      "on_merge_fn": "merge_callback_animal_model_v1"
    },
    {
      "description": "route 1, use animal_model_v2 (yolo_small)",
      "kind": "channel_spout",
      "id": 7,
      "source": 2,
      "timeout": 10,
      "max_age_ns": 1000000000
